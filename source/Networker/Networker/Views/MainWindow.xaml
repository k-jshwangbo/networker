<Window x:Class="Networker.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Networker.Views"
        xmlns:vm="clr-namespace:Networker.ViewModels"
        Title="Networker" Height="640" Width="960"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <TabControl Margin="8">
        <TabItem Header="Ping">
            <views:PingView DataContext="{Binding Ping}"/>
        </TabItem>

        <TabItem Header="Remote Port Scan">
            <views:PortScanView DataContext="{Binding PortScan}"/>
        </TabItem>

        <!-- Future tabs (wire up as features land) -->
        <TabItem Header="Local Ports" IsEnabled="False"/>
        <TabItem Header="Range Scan" IsEnabled="False"/>
        <TabItem Header="Traceroute" IsEnabled="False"/>
        <TabItem Header="DNS" IsEnabled="False"/>
    </TabControl>
</Window>
