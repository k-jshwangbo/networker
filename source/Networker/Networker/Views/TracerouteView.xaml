<UserControl x:Class="Networker.Views.TracerouteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:Networker.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:TracerouteViewModel}"
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Input controls -->
        <ui:Card Grid.Row="0" Margin="0,0,0,8" Padding="10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Host:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ui:TextBox Width="170" VerticalAlignment="Center"
                            PlaceholderText="hostname or IP"
                            Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Max hops:" VerticalAlignment="Center" Margin="12,0,4,0"/>
                <ui:TextBox Width="50" VerticalAlignment="Center" Text="{Binding MaxHops}"/>

                <TextBlock Text="Probes:" VerticalAlignment="Center" Margin="12,0,4,0"/>
                <ui:TextBox Width="46" VerticalAlignment="Center" Text="{Binding ProbesPerHop}"/>

                <TextBlock Text="Timeout (ms):" VerticalAlignment="Center" Margin="12,0,4,0"/>
                <ui:TextBox Width="60" VerticalAlignment="Center" Text="{Binding TimeoutMs}"/>

                <ui:ToggleSwitch Content="Resolve names" VerticalAlignment="Center" Margin="16,0,0,0"
                                 IsChecked="{Binding ResolveHostNames}"/>

                <ui:Button Content="Start" Appearance="Primary" Margin="16,0,0,0"
                           Icon="{ui:SymbolIcon Play24}" Command="{Binding StartCommand}"/>
                <ui:Button Content="Stop" Margin="6,0,0,0"
                           Icon="{ui:SymbolIcon Stop24}" Command="{Binding StopCommand}"/>
                <ui:Button Content="Clear" Margin="6,0,0,0"
                           Icon="{ui:SymbolIcon Delete24}" Command="{Binding ClearCommand}"/>
            </StackPanel>
        </ui:Card>

        <!-- Progress + error (display-only -> OneWay) -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <ProgressBar Height="18" Minimum="0"
                         Maximum="{Binding MaxHops, Mode=OneWay}"
                         Value="{Binding CurrentHop, Mode=OneWay}"/>
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                       VerticalAlignment="Center" Margin="6,0,0,0"/>
        </Grid>

        <!-- Hops grid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Hops}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  RowHeaderWidth="0"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Hop"       Binding="{Binding Hop}"         Width="45"/>
                <DataGridTextColumn Header="Address"   Binding="{Binding AddressText}" Width="130"/>
                <DataGridTextColumn Header="Host Name" Binding="{Binding HostNameText}" Width="220"/>
                <DataGridTextColumn Header="RTT (ms)"  Binding="{Binding RttText}"     Width="160"/>
                <DataGridTextColumn Header="Status"    Binding="{Binding StatusText}"  Width="140"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status bar -->
        <ui:Card Grid.Row="3" Margin="0,8,0,0" Padding="10,6">
            <TextBlock Text="{Binding StatusSummary}" FontWeight="SemiBold"/>
        </ui:Card>
    </Grid>
</UserControl>
