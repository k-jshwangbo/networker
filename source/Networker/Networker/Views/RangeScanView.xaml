<UserControl x:Class="Networker.Views.RangeScanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:Networker.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:RangeScanViewModel}"
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Input controls -->
        <ui:Card Grid.Row="0" Margin="0,0,0,8" Padding="10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Target:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ui:TextBox Width="200" VerticalAlignment="Center"
                            PlaceholderText="192.168.0.0/24"
                            ToolTip="CIDR, range, or single IP. e.g. 192.168.0.0/24, 192.168.0.1-254, 10.0.0.5"
                            Text="{Binding TargetText, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Timeout (ms):" VerticalAlignment="Center" Margin="12,0,4,0"/>
                <ui:TextBox Width="60" VerticalAlignment="Center" Text="{Binding PingTimeoutMs}"/>

                <TextBlock Text="Threads:" VerticalAlignment="Center" Margin="12,0,4,0"/>
                <ui:TextBox Width="55" VerticalAlignment="Center" Text="{Binding MaxConcurrency}"/>

                <ui:ToggleSwitch Content="Resolve names" VerticalAlignment="Center" Margin="16,0,0,0"
                                 IsChecked="{Binding ResolveHostNames}"/>

                <ui:Button Content="Start" Appearance="Primary" Margin="16,0,0,0"
                           Icon="{ui:SymbolIcon Play24}" Command="{Binding StartCommand}"/>
                <ui:Button Content="Stop" Margin="6,0,0,0"
                           Icon="{ui:SymbolIcon Stop24}" Command="{Binding StopCommand}"/>
                <ui:Button Content="Clear" Margin="6,0,0,0"
                           Icon="{ui:SymbolIcon Delete24}" Command="{Binding ClearCommand}"/>
            </StackPanel>
        </ui:Card>

        <!-- Progress + error (display-only -> OneWay) -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <ProgressBar Height="18" Minimum="0"
                         Maximum="{Binding Total, Mode=OneWay}"
                         Value="{Binding Scanned, Mode=OneWay}"/>
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                       VerticalAlignment="Center" Margin="6,0,0,0"/>
        </Grid>

        <!-- Alive hosts grid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding AliveHosts}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  RowHeaderWidth="0"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="IP Address" Binding="{Binding AddressText}"     Width="130"/>
                <DataGridTextColumn Header="Host Name"  Binding="{Binding HostNameText}"    Width="200"/>
                <DataGridTextColumn Header="MAC"        Binding="{Binding MacText}"         Width="150"/>
                <DataGridTextColumn Header="Ping (ms)"  Binding="{Binding PingText}"        Width="80"/>
                <DataGridTextColumn Header="Found via"  Binding="{Binding DiscoveryMethod}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status bar -->
        <ui:Card Grid.Row="3" Margin="0,8,0,0" Padding="10,6">
            <TextBlock Text="{Binding StatusSummary}" FontWeight="SemiBold"/>
        </ui:Card>
    </Grid>
</UserControl>
