<UserControl x:Class="Networker.Views.RoutingTableView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:Networker.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:RoutingTableViewModel}"
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ui:Card Grid.Row="0" Margin="0,0,0,8" Padding="10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ui:Button Content="Refresh" Appearance="Primary"
                           Icon="{ui:SymbolIcon ArrowClockwise24}"
                           Command="{Binding RefreshCommand}"/>
                <TextBlock VerticalAlignment="Center" Margin="12,0,0,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="IPv4 routing table (read-only)."/>
            </StackPanel>
        </ui:Card>

        <!-- Error -->
        <ui:TextBlock Grid.Row="1" Text="{Binding ErrorMessage}"
                      Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                      Margin="2,0,0,8" TextWrapping="Wrap"/>

        <!-- Routes grid -->
        <DataGrid Grid.Row="2" ContextMenu="{StaticResource GridContextMenu}"
                  ItemsSource="{Binding Routes}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  RowHeaderWidth="0"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  CanUserAddRows="False"
                  CanUserSortColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Destination" Binding="{Binding DestinationCidr}" Width="160" FontFamily="Consolas"/>
                <DataGridTextColumn Header="Gateway"     Binding="{Binding GatewayText}"     Width="140" FontFamily="Consolas"/>
                <DataGridTextColumn Header="Interface"   Binding="{Binding InterfaceText}"   Width="*"/>
                <DataGridTextColumn Header="Metric"      Binding="{Binding Metric}"          Width="70"/>
                <DataGridTextColumn Header="Type"        Binding="{Binding RouteType}"       Width="90"/>
                <DataGridTextColumn Header="Protocol"    Binding="{Binding Protocol}"        Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status bar -->
        <ui:Card Grid.Row="3" Margin="0,8,0,0" Padding="10,6">
            <TextBlock Text="{Binding StatusSummary}" FontWeight="SemiBold"/>
        </ui:Card>
    </Grid>
</UserControl>
