<UserControl x:Class="Networker.Views.BannerGrabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:Networker.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:BannerGrabViewModel}"
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Input controls -->
        <ui:Card Grid.Row="0" Margin="0,0,0,8" Padding="10">
            <StackPanel>
                <!-- Row A: targets -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Host:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ui:TextBox Width="160" VerticalAlignment="Center"
                                PlaceholderText="hostname or IP"
                                Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Ports:" VerticalAlignment="Center" Margin="12,0,4,0"/>
                    <ui:TextBox Width="320" VerticalAlignment="Center"
                                PlaceholderText="21,22,80,443 or 1-1024"
                                ToolTip="Comma list and/or ranges, e.g. 21,22,80,443,8000-8100"
                                Text="{Binding PortRangeText, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Timeout (ms):" VerticalAlignment="Center" Margin="12,0,4,0"/>
                    <ui:TextBox Width="64" VerticalAlignment="Center" Text="{Binding TimeoutMs}"/>

                    <TextBlock Text="Threads:" VerticalAlignment="Center" Margin="12,0,4,0"/>
                    <ui:TextBox Width="55" VerticalAlignment="Center" Text="{Binding MaxConcurrency}"/>
                </StackPanel>

                <!-- Row B: options + actions -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,10,0,0">
                    <ui:ToggleSwitch Content="TLS on secure ports" VerticalAlignment="Center"
                                     IsChecked="{Binding UseTls}"/>
                    <ui:ToggleSwitch Content="HTTP probe" VerticalAlignment="Center" Margin="16,0,0,0"
                                     IsChecked="{Binding SendHttpProbe}"/>

                    <TextBlock Text="Custom probe:" VerticalAlignment="Center" Margin="16,0,4,0"/>
                    <ui:TextBox Width="200" VerticalAlignment="Center"
                                PlaceholderText="optional, \r\n for CRLF"
                                ToolTip="Raw bytes to send after connecting. Overrides the HTTP probe."
                                Text="{Binding CustomProbe, UpdateSourceTrigger=PropertyChanged}"/>

                    <ui:Button Content="Start" Appearance="Primary" Margin="16,0,0,0"
                               Icon="{ui:SymbolIcon Play24}" Command="{Binding StartCommand}"/>
                    <ui:Button Content="Stop" Margin="6,0,0,0"
                               Icon="{ui:SymbolIcon Stop24}" Command="{Binding StopCommand}"/>
                    <ui:Button Content="Clear" Margin="6,0,0,0"
                               Icon="{ui:SymbolIcon Delete24}" Command="{Binding ClearCommand}"/>
                </StackPanel>
            </StackPanel>
        </ui:Card>

        <!-- Progress + error -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <ProgressBar Height="18" Minimum="0"
                         Maximum="{Binding Total, Mode=OneWay}"
                         Value="{Binding Scanned, Mode=OneWay}"/>
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                       VerticalAlignment="Center" Margin="6,0,0,0"/>
        </Grid>

        <!-- Banners grid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Banners}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  RowHeaderWidth="0"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Port"    Binding="{Binding Port}"        Width="60"/>
                <DataGridTextColumn Header="Service" Binding="{Binding Service}"     Width="110"/>
                <DataGridTextColumn Header="TLS"     Binding="{Binding IsTlsText}"   Width="50"/>
                <DataGridTextColumn Header="Status"  Binding="{Binding StatusText}"  Width="90"/>
                <DataGridTextColumn Header="Bytes"   Binding="{Binding BytesRead}"   Width="64"/>
                <DataGridTextColumn Header="Banner"  Binding="{Binding Banner}"      Width="*"
                                    FontFamily="Consolas"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status bar -->
        <ui:Card Grid.Row="3" Margin="0,8,0,0" Padding="10,6">
            <TextBlock Text="{Binding StatusSummary}" FontWeight="SemiBold"/>
        </ui:Card>
    </Grid>
</UserControl>
